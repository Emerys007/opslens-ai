{
  "uid": "opslens_ai_app",
  "type": "app",
  "config": {
    "description": "An example to demonstrate how to build a private oauth app with developer projects.",
    "name": "opslens-ai-App",
    "distribution": "marketplace",
    "auth": {
      "type": "oauth",
      "redirectUrls": [
        "https://api.app-sync.com/oauth-callback"
      ],
      "requiredScopes": [
        "oauth",
        "crm.objects.contacts.read",
        "crm.objects.contacts.write",
        "crm.schemas.contacts.write",
        "tickets",
        "automation",
        "crm.schemas.contacts.read",
        "crm.schemas.companies.read",
        "crm.schemas.deals.read"
      ],
      "optionalScopes": [],
      "conditionallyRequiredScopes": []
    },
    "permittedUrls": {
      "fetch": [
        "https://api.hubapi.com",
        "https://opslens.local",
        "https://api.app-sync.com"
      ],
      "iframe": [],
      "img": []
    },
    "support": {
      "supportEmail": "support@app-sync.com",
      "documentationUrl": "https://apps.app-sync.com/opslens/setup/",
      "supportUrl": "https://apps.app-sync.com/opslens/"
    }
  }
}
