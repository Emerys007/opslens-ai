{
  "uid": "opslens_ai_app",
  "type": "app",
  "config": {
    "description": "OpsLens AI watches your HubSpot portal for workflow-breaking changes — archived properties, disabled workflows, schema edits — and alerts your team in Slack and HubSpot tickets with plain-English explanations of what broke and how to fix it.",
    "name": "OpsLens AI",
    "distribution": "marketplace",
    "auth": {
      "type": "oauth",
      "redirectUrls": [
        "https://api.app-sync.com/oauth-callback"
      ],
      "requiredScopes": [
        "oauth",
        "crm.objects.contacts.read",
        "crm.objects.contacts.write",
        "crm.schemas.contacts.write",
        "tickets",
        "automation",
        "crm.schemas.contacts.read",
        "crm.schemas.companies.read",
        "crm.schemas.deals.read",
        "crm.lists.read",
        "content"
      ],
      "optionalScopes": [],
      "conditionallyRequiredScopes": []
    },
    "permittedUrls": {
      "fetch": [
        "https://api.hubapi.com",
        "https://opslens.local",
        "https://api.app-sync.com"
      ],
      "iframe": [],
      "img": []
    },
    "support": {
      "supportEmail": "support@app-sync.com",
      "documentationUrl": "https://apps.app-sync.com/opslens/setup/",
      "supportUrl": "https://apps.app-sync.com/opslens/"
    }
  }
}
