# Copy this file to .env later.

# Core app settings
APP_NAME=OpsLens AI
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=

# HubSpot OAuth and webhook settings
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=
HUBSPOT_APP_ID=
HUBSPOT_WEBHOOK_SECRET=
HUBSPOT_SCOPES=oauth crm.objects.contacts.read crm.objects.contacts.write crm.schemas.contacts.write tickets automation crm.schemas.contacts.read crm.schemas.companies.read crm.schemas.deals.read crm.schemas.tickets.read
HUBSPOT_OPTIONAL_SCOPES=
HUBSPOT_VALIDATE_SIGNATURE=true
OAUTH_STATE_SECRET=
OAUTH_STATE_TTL_SECONDS=900

# Ticket pipeline overrides
HUBSPOT_OPSLENS_PIPELINE_ID=890820374
HUBSPOT_OPSLENS_STAGE_NEW_ALERT=1341759033
HUBSPOT_OPSLENS_STAGE_INVESTIGATING=1341759034
HUBSPOT_OPSLENS_STAGE_WAITING=1341759035
HUBSPOT_OPSLENS_STAGE_RESOLVED=1341759036
HUBSPOT_OPSLENS_STAGE_DUPLICATE=1341759037
HUBSPOT_OPSLENS_REOPEN_WINDOW_HOURS=168

# Maintenance cron settings
OPSLENS_MAINTENANCE_KEY=
OPSLENS_API_BASE_URL=https://api.app-sync.com
OPSLENS_AUTO_RESOLVE_QUIET_HOURS=24
OPSLENS_AUTO_RESOLVE_MAX_RECORDS=200
